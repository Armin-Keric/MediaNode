<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="500.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/21.0.6" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.frontend.controller.authentication.SigninController">
   <children>
      <Text layoutY="100.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Sign In" textAlignment="CENTER" wrappingWidth="300.0">
         <font>
            <Font name="System Bold" size="40.0" />
         </font>
      </Text>
      <TextField fx:id="usernameField" layoutX="15.0" layoutY="241.0" prefHeight="25.0" prefWidth="271.0" promptText="MaxMustermann" />
      <TextField fx:id="passwordTextField" layoutX="15.0" layoutY="293.0" prefHeight="25.0" prefWidth="235.0" visible="false" managed="false"/>
      <PasswordField fx:id="passwordField" layoutX="15.0" layoutY="293.0" prefHeight="25.0" prefWidth="235.0" promptText="Password" />
      <Text layoutX="15.0" layoutY="240.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Username:" />
      <Text layoutX="15.0" layoutY="290.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Password:" />
      <Button layoutX="255.0" layoutY="291.0" mnemonicParsing="false" onAction="#onShowPasswordClicked" text="👁" />
      <Button layoutX="119.0" layoutY="400.0" mnemonicParsing="false" onAction="#onConfirmSignInClicked" text="Confirm" textAlignment="CENTER">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button layoutX="5.0" layoutY="5.0" mnemonicParsing="false" onAction="#onBackClicked" text="&lt;=" />
      <Label fx:id="warningLabel" layoutX="15.0" layoutY="323.0" prefHeight="17.0" prefWidth="271.0" textFill="RED" />
   </children>
</AnchorPane>
