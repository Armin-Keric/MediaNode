<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" stylesheets="@../../style/browse-style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.frontend.controller.content.MediaListViewController">
    <content>
        <VBox alignment="TOP_CENTER" spacing="30.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <VBox spacing="10.0" maxWidth="1000.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #555;" text="CONSUMING" />
                        <VBox fx:id="consumingArea" alignment="TOP_CENTER" minHeight="100.0" style="-fx-background-color: rgba(0,0,0,0.05); -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="10.0" maxWidth="1000.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #555;" text="COMPLETED" />
                        <VBox fx:id="completedArea" alignment="TOP_CENTER" minHeight="100.0" style="-fx-background-color: rgba(0,0,0,0.05); -fx-background-radius: 5;" />
                    </children>
                </VBox>

                <VBox spacing="10.0" maxWidth="1000.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #555;" text="PLANNING" />
                        <VBox fx:id="planningArea" alignment="TOP_CENTER" minHeight="100.0" style="-fx-background-color: rgba(0,0,0,0.05); -fx-background-radius: 5;" />
                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>