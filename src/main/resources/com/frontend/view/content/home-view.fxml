<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" pannable="true" stylesheets="@../../style/home-style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.frontend.controller.content.HomeViewController">
   <content>
      <VBox alignment="TOP_CENTER" spacing="20.0">
         <children>

            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <BorderPane maxWidth="1000.0">
                     <left>
                        <Button mnemonicParsing="false" onAction="#onPreviousClicked" text="&lt;" BorderPane.alignment="CENTER" />
                     </left>
                     <center>
                        <ImageView fx:id="mainCarouselImageView" fitHeight="400.0" fitWidth="700.0" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER" />
                     </center>
                     <right>
                        <Button mnemonicParsing="false" onAction="#onNextClicked" text="&gt;" BorderPane.alignment="CENTER" />
                     </right>
                     <bottom>
                        <HBox fx:id="paginationContainer" alignment="CENTER" spacing="8.0" />
                     </bottom>
                  </BorderPane>
               </children>
               <padding>
                  <Insets bottom="10.0" top="20.0" />
               </padding>
            </VBox>

            <VBox alignment="TOP_CENTER" maxWidth="1000.0" spacing="15.0">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label text="Trending:" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #555;" />
                     </children>
                     <padding>
                        <Insets left="20.0" />
                     </padding>
                  </HBox>

                  <HBox fx:id="trendingArea" alignment="CENTER" spacing="15.0">
                     <padding>
                        <Insets bottom="20.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </content>
</ScrollPane>
