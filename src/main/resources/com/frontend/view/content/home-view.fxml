<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" pannable="true" stylesheets="@../../style/home-style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.frontend.controller.content.HomeViewController">
   <content>
      <VBox alignment="TOP_CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <VBox alignment="CENTER" spacing="15.0">
               <children>
                  <BorderPane maxWidth="1000.0">
                     <left>
                        <Button mnemonicParsing="false" onAction="#onPreviousClicked" text="&lt;" BorderPane.alignment="CENTER" />
                     </left>
                     <center>
                        <ImageView fx:id="mainCarouselImageView" fitHeight="400.0" fitWidth="700.0" pickOnBounds="true" preserveRatio="true" BorderPane.alignment="CENTER" />
                     </center>
                     <right>
                        <Button mnemonicParsing="false" onAction="#onNextClicked" text="&gt;" BorderPane.alignment="CENTER" />
                     </right>
                     <bottom>
                        <HBox fx:id="paginationContainer" alignment="CENTER" spacing="8.0" />
                     </bottom>
                  </BorderPane>
               </children>

               <padding>
                  <Insets top="20.0" bottom="20.0" />
               </padding>
            </VBox>

            <VBox fx:id="futureContentArea" alignment="CENTER" prefHeight="600.0" spacing="20.0">
            </VBox>

         </children>
      </VBox>
   </content>
</ScrollPane>